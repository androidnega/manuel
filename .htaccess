Options -Indexes
RewriteEngine On
RewriteBase /

# Legacy /manuelcode/... → /... (301 to domain root)
RewriteRule ^manuelcode/?(.*)$ /$1 [R=301,L]

# Browser request: strip .php from visible URL
RewriteCond %{THE_REQUEST} \s/+((?:manuelcode/)?[^\s?]+)\.php[\s?] [NC]
RewriteRule ^ /%1? [R=301,L]

RewriteCond %{THE_REQUEST} \s/+((?:manuelcode/)?)index\.php[\s?] [NC]
RewriteRule ^ /? [R=301,L]

# Extensionless → .php (internal)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^([a-z][a-z0-9-]*)/?$ $1.php [L]

<FilesMatch "\.(sql|env|ini|log)$">
  Require all denied
</FilesMatch>
