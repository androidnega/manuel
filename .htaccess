Options -Indexes
RewriteEngine On
RewriteBase /

# Legacy /manuelcode/... → /... (301 to domain root)
RewriteRule ^manuelcode/?(.*)$ /$1 [R=301,L]

# Common mistyped slugs
RewriteRule ^project/?$ /projects [R=301,L]

# Browser request: strip .php from visible URL
RewriteCond %{THE_REQUEST} \s/+((?:manuelcode/)?[^\s?]+)\.php[\s?] [NC]
RewriteRule ^ /%1? [R=301,L]

RewriteCond %{THE_REQUEST} \s/+((?:manuelcode/)?)index\.php[\s?] [NC]
RewriteRule ^ /? [R=301,L]

# SEO
RewriteRule ^robots\.txt$ robots.php [L]
RewriteRule ^sitemap\.xml$ sitemap.php [L]

# Legacy image paths → SEO filenames
RewriteRule ^assets/images/quote-poster-original\.(jpg|png)$ /assets/images/manuelcode-leadership-quote-poster-design-ghana.jpg [R=301,L]
RewriteRule ^assets/images/manuel-portrait\.(jpg|png)$ /assets/images/manuel-kwofie-software-engineer-portrait-ghana.jpg [R=301,L]
RewriteRule ^assets/images/brand-guide\.(jpg|png)$ /assets/images/manuelcode-brand-identity-design-guide.jpg [R=301,L]
RewriteRule ^assets/images/main-logo\.png$ /assets/images/manuelcode-logo-main.png [R=301,L]
RewriteRule ^assets/images/dark-logo\.(png|webp)$ /assets/images/manuelcode-logo-dark.webp [R=301,L]
RewriteRule ^assets/images/favicon\.(png|webp)$ /assets/images/manuelcode-favicon.webp [R=301,L]
RewriteRule ^assets/images/bring-me-work-promo\.png$ /assets/images/manuelcode-bring-me-work-promo-software-ghana.png [R=301,L]

# News article: /news/my-post-slug
RewriteRule ^news/([a-z0-9-]+)/?$ news-article.php?slug=$1 [L,QSA]

# Extensionless → .php (internal)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^([a-z][a-z0-9-]*)/?$ $1.php [L]

<FilesMatch "\.(sql|env|ini|log)$">
  Require all denied
</FilesMatch>
